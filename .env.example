# =============================================
# WebsiteProfiling Platform - Environment Config
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database ---
POSTGRES_USER=websiteprofiling
POSTGRES_PASSWORD=websiteprofiling
POSTGRES_DB=websiteprofiling
DATABASE_URL=postgresql+asyncpg://websiteprofiling:websiteprofiling@localhost:5432/websiteprofiling

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- SERP / Keyword Data APIs ---
# DataForSEO (https://dataforseo.com) - Recommended for best data
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# SerpApi (https://serpapi.com) - Alternative
SERP_API_KEY=

# --- AI / LLM APIs ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# --- Google OAuth2 (for GSC, GA4, GBP) ---
# Create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Social Media APIs ---
# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Facebook / Instagram
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# YouTube / Google Ads
YOUTUBE_API_KEY=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# --- Notifications ---
# Slack
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# --- GeoIP (MaxMind) ---
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=./GeoLite2-City.mmdb

# --- Encryption ---
# Used for encrypting OAuth tokens in database
ENCRYPTION_KEY=

# --- Frontend ---
# Base URL for JSON API (must include /api/v1). Docker Compose: same host:8000 as published backend port.
# If you open the UI from another machine, use that machine-reachable host, e.g. http://192.168.1.10:8000/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# --- Development ---
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development
